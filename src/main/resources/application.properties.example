spring.application.name=cloud
jwt.secret=someverylongsecretkeyforjwt1234567890
aws.iot.endpoint=someendpoint-ats.iot.us-east-1.amazonaws.com
aws.iot.clientId=iot-client
logging.level.root=INFO
logging.level.uy.plomo.cloud=DEBUG
springdoc.swagger-ui.persistAuthorization=true
springdoc.swagger-ui.tagsSorter=alpha
port.pool.start=9000
port.pool.end=9999
iot.instanceName=instance_name
logging.level.org.springframework.security=DEBUG
tunnel.server.host=<server_ip>
aws.region=us-east-1

# --- PostgreSQL ---
spring.datasource.url=jdbc:postgresql://localhost:5432/iot_backend
spring.datasource.username=app
spring.datasource.password=secret
spring.datasource.driver-class-name=org.postgresql.Driver

# HikariCP connection pool
spring.datasource.hikari.maximum-pool-size=10
spring.datasource.hikari.minimum-idle=2
spring.datasource.hikari.connection-timeout=30000

# --- JPA / Hibernate ---
# validate: Flyway es el dueño del schema, Hibernate solo valida que coincida
spring.jpa.hibernate.ddl-auto=validate
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.open-in-view=false

# --- Flyway ---
spring.flyway.enabled=true
spring.flyway.locations=classpath:db/migration

# --- Kafka (It2) ---
spring.kafka.bootstrap-servers=localhost:9092

# Producer
spring.kafka.producer.key-serializer=org.apache.kafka.common.serialization.StringSerializer
spring.kafka.producer.value-serializer=org.springframework.kafka.support.serializer.JsonSerializer
# Agrega header __TypeId__ con el FQCN — el consumer lo usa para deserializar sin ambigüedad
spring.kafka.producer.properties.spring.json.add.type.headers=true

# Consumer — el ConsumerFactory explícito en KafkaConfig usa estas props también
spring.kafka.consumer.group-id=iot-backend
spring.kafka.consumer.auto-offset-reset=earliest
spring.kafka.consumer.enable-auto-commit=true
# Deserialización JSON del value — reemplaza al ConsumerFactory explícito con JsonDeserializer deprecated
spring.kafka.consumer.value-deserializer=org.springframework.kafka.support.serializer.JsonDeserializer
spring.kafka.consumer.properties.spring.json.value.default.type=uy.plomo.cloud.kafka.event.TelemetryEvent
spring.kafka.consumer.properties.spring.json.trusted.packages=uy.plomo.cloud.kafka.event
